@page
@model IndexModel
@{
    ViewData["Title"] = "";
}


<!-- ======== CABEÇALHO ======== -->
<header id="inicio">

    <nav class="navbar navbar-expand-lg">
        <div class="container">

            <!-- LOGO -->
            <a href="#inicio" class="logo-link">
                <img src="~/images/favicon.png" alt="Logo" class="logo-img" />
            </a>

            <!-- BOTÃO -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#menuPrincipal"
                    aria-controls="menuPrincipal"
                    aria-expanded="false"
                    aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- MENU -->
            <div class="collapse navbar-collapse" id="menuPrincipal">
                <ul class="navbar-nav ms-auto menu-principal">

                    @*  <li class="nav-item">
                        <a class="nav-link" href="#inicio">Início</a>
                    </li> *@
                    

                    <li class="nav-item">
                        <a class="nav-link" href="#sobre">Sobre Mim</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#projetos">Projetos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#skills">Habilidades</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contato">Contato</a>
                    </li>
                </ul>
            </div>

        </div>
    </nav>


    
    <div class="header-content container">
        <div class="texto-cabecalho">
            <p class="subtitulo">Desenvolvedor FullStack</p>
            <h1>Olá, eu sou <br> <span class="destaque">Bryan Albuquerque</span></h1>
        </div>
    </div>
</header>


<!-- ======== SOBRE ======== -->
<section id="sobre">
    <div class="container">
        <div class="linha">
            <div class="coluna-imagem">
                <img src="~/Images/Bryan.png" alt="Foto de Bryan Albuquerque" class="foto-perfil" />
            </div>

            <div class="coluna-texto">
                <h2 class="titulo-secao">Sobre Mim</h2>
                <p class="texto">
                    Formação em Análise e Desenvolvimento de Sistemas pela Universidade Paulista (UNIP) e atuo diariamente no desenvolvimento de soluções tecnológicas sob medida.
                </p>
                <p class="texto">
                    Tenho experiência na criação de sistemas desktop e aplicações web, desenvolvendo desde a análise de requisitos, lógica e arquitetura do sistema, até a implementação, testes e manutenção.
                </p>
                <p class="texto">
                    Trabalho com foco em performance, organização de código e usabilidade, entregando soluções eficientes, seguras e alinhadas às necessidades do cliente.
                </p>

                <p class="texto">
                    💻 O que posso desenvolver para você:
                    <ul>
                        <li>Sistemas Desktop personalizados</li>
                        <li>Sistemas Web e Sites institucionais</li>
                        <li>Funcionalidades sob demanda e manutenção de sistemas existentes</li>
                    </ul>

                    <p class="texto">
                    📩 Estou à disposição para atuar como desenvolvedor do seu Sistema ou Site.
                    para entrar em contato. 👉 <a href="#contato"> Clique aqui!</a>
                    </p>
                    
            </div>
        </div>
    </div>
</section>

